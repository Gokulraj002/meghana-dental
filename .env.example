# ── Database ─────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://root:password@localhost:3306/meghana_dental"

# ── Admin Auth ───────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET="meghana-dental-admin-secret-key-change-this"

# ── First-time Setup ─────────────────────────────────────────
# Key required to create the first admin account via /admin/setup
SETUP_KEY="meghana-setup-2024"

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://meghanadental.in"
